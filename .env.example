# App
APP_ENV=local
DEBUG=True
APP_NAME=agent-graph-platform
BOOTSTRAP_FAIL_FAST=False
POSTGRES_IMAGE=postgres:16
PIP_INDEX_URL=https://pypi.org/simple

# Sentry
SENTRY_DSN=
SENTRY_DEBUG_ENABLED=False

# Main Postgres
# REQUIRED: the app refuses to start if these are unset or left at the
# placeholder. Override per environment; never reuse the values below in prod.
MAIN_POSTGRES_USER=test
MAIN_POSTGRES_PASS=test
MAIN_POSTGRES_HOST=localhost
MAIN_POSTGRES_PORT=5432
MAIN_POSTGRES_DATABASE=platform_agent
LOCAL_MAIN_POSTGRES_HOST=localhost
MAIN_POSTGRES_TIMEOUT=10000
MAIN_POSTGRES_ACQUIRE_TIMEOUT_IN_SECONDS=10
MAIN_POSTGRES_POOL_MAX_INACTIVE_CONNECTION_LIFETIME=300
MAIN_POSTGRES_CONNECTION_POOL_MIN_SIZE=2
MAIN_POSTGRES_CONNECTION_POOL_MAX_SIZE=8

# Schemas / Agno storage (Agno reuses the main Postgres database, schema and table names only)
PLATFORM_SCHEMA=platform
VENDOR_SCHEMA=vendor
ANALYTICS_SCHEMA=analytics
ANALYTICS_RETENTION_DAYS=180
ANALYTICS_REFRESH_WINDOW_DAYS=7
AGNO_DB_SCHEMA=agno
AGNO_DB_INIT_FAIL_FAST=False
AGNO_SESSION_TABLE=agno_sessions
AGNO_MEMORY_TABLE=agno_memories
AGNO_METRICS_TABLE=agno_metrics
AGNO_EVAL_TABLE=agno_eval_runs
AGNO_KNOWLEDGE_TABLE=agno_knowledge
AGNO_TRACES_TABLE=agno_traces
AGNO_SPANS_TABLE=agno_spans
AGNO_VERSIONS_TABLE=agno_schema_versions
AGNO_LEARNINGS_TABLE=agno_learnings

# Model
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=60
OPENROUTER_PROXY=
AGNO_MODEL=openai/gpt-4o
OPENROUTER_TOOL_MODEL=openai/gpt-4o-mini

# Platform
PLATFORM_CACHE_EAGER_LOAD=True
PLATFORM_MAX_GRAPH_DEPTH=8
PLATFORM_DEFAULT_HISTORY_RUNS=12
PLATFORM_DEFAULT_TOOL_CALL_LIMIT=20
PLATFORM_DEFAULT_SESSION_TABLE=agno_sessions
PLATFORM_RUNTIME_CACHE_ENABLED=True
MCP_DEFAULT_TIMEOUT_SECONDS=15
MCP_ROOT_DIR=
SKILLS_ROOT_DIR=

# Analytics source
CLICKHOUSE_MODE=http
CLICKHOUSE_HTTP_BASE_URL=
CLICKHOUSE_HTTP_API_KEY=
CLICKHOUSE_USE_PROXY=False
CLICKHOUSE_NATIVE_HOST=
CLICKHOUSE_NATIVE_PORT=9440
CLICKHOUSE_NATIVE_USER=
CLICKHOUSE_NATIVE_PASSWORD=
CLICKHOUSE_NATIVE_DATABASE=OLAPBasalam
CLICKHOUSE_NATIVE_SECURE=True

# Platform Admin MCP
PLATFORM_ADMIN_MCP_HOST=127.0.0.1
PLATFORM_ADMIN_MCP_PORT=9015
ADMIN_SECRET_KEY=
ADMIN_SECRET_HEADER_NAME=X-Admin-Secret-Key

# Task tools
TASK_PLATFORM_API_BASE_URL=http://127.0.0.1:8000
TASK_PLATFORM_API_TIMEOUT_SECONDS=30

# Vendor Support
# Base host only — the SDK appends the "/agno/call-direct" path itself.
VENDOR_SUPPORT_TICKET_API_URL=https://ticket-agent-2.titanapp.dev
VENDOR_AUTH_USER_API_URL=https://services.basalam.com/web/v1/core/user
VENDOR_AUTH_REQUEST_TIMEOUT_SECONDS=15
VENDOR_AUTH_DEFAULT_ORIGIN=https://basalam.com
VENDOR_AUTH_DEFAULT_REFERER=https://basalam.com/

# Basalam OpenAPI (basalam-sdk credentials registered at developers.basalam.com).
# Access tokens themselves come from the incoming request.
BASALAM_CLIENT_ID=
BASALAM_CLIENT_SECRET=

# Per-agent Telegram and Bale channels are configured through the admin API.
# Bot tokens are encrypted at rest. Generate a key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Comma-separated for rotation (first key encrypts, all keys decrypt).
CHANNEL_TOKEN_ENCRYPTION_KEY=
# Public HTTPS origin of this service, without a trailing slash. The admin
# webhook action uses it to build each bot's secure callback URL.
CHANNEL_PUBLIC_BASE_URL=
CHANNEL_ERROR_MESSAGE=متأسفانه هنگام پردازش پیام خطایی رخ داد. لطفاً دوباره تلاش کنید.

# Process-local caching
CACHE_TOOLS_TTL_SECONDS=60

NUMBERLAND_ORDER_BASE_URL=https://order.numberland.ir
NUMBERLAND_AUTH_BASE_URL=https://auth.numberland.ir
NUMBERLAND_CLIENT_ID=
NUMBERLAND_CLIENT_SECRET=
NUMBERLAND_REQUEST_TIMEOUT_SECONDS=20
NUMBERLAND_TOKEN_REFRESH_SKEW_SECONDS=30
